<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg900">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarLegal"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg900"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Legal Disposal"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text"
            android:layout_marginStart="16dp"
            android:layout_gravity="center_vertical"/>
    </androidx.appcompat.widget.Toolbar>

    <!-- Public Dustbins -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardDustbin"
        style="@style/GlassCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarLegal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnDustbin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:text="🗑️ Public Dustbins / Disposal Areas"
            android:textColor="@color/text"
            android:textSize="18sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <!-- E-Waste -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardEwaste"
        style="@style/GlassCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/cardDustbin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnEwaste"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:text="🧯 Waste\E-Waste Collection Centers"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text"/>
    </androidx.cardview.widget.CardView>

    <!-- Scrap -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnScrap"
        style="@style/GlassCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/cardEwaste"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
